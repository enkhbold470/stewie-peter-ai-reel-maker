# Copy to .env and fill in values (never commit .env).

OPENAI_API_KEY=

# Required for real deployments (Flask sessions).
SECRET_KEY=

# HTTP port for python -m backend.main
PORT=5001

# Comma-separated browser origins for CORS (dev defaults include Vite).
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Local-only: bypass login on /api/script, /api/generate, /api/output/*
# SKIP_AUTH=1

# Max background upload size (MB) for /api/generate. Default 256.
# MAX_UPLOAD_MB=256
