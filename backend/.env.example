# Copy to .env and fill in values (never commit .env).

OPENAI_API_KEY=

# OpenAI-compatible base URL for chat + Whisper (Dedalus, etc.). Trailing slash optional.
OPENAI_BASE_URL=https://api.dedaluslabs.ai/v1

# Optional: default chat model for script drafts (Dedalus-style ids, e.g. xai/grok-4-fast-reasoning).
# DEFAULT_GPT_MODEL=xai/grok-4-fast-reasoning

# Optional: comma-separated Kokoro voice ids (merged into /api/options tts_voices).
# KOKORO_EXTRA_VOICES=bm_george,af_bella

# PostgreSQL (required for the web app; Alembic migrations in backend/alembic/versions/).
# DATABASE_URL=postgresql://brainrot:brainrot@localhost:5432/brainrot

# Required for real deployments (Flask sessions).
SECRET_KEY=

# HTTP bind (uvicorn); use 0.0.0.0 in Docker / behind Traefik
# HOST=0.0.0.0

# HTTP port for python -m backend.main (uvicorn WSGI)
PORT=5001

# Comma-separated browser origins for CORS (dev defaults include Vite).
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Flask-Limiter: per-IP limits (memory:// default; use redis:// for multi-worker).
# RATELIMIT_ENABLED=1
# RATELIMIT_STORAGE_URI=memory://

# Local-only: bypass login on /api/script, /api/generate, /api/output/*
# SKIP_AUTH=1

# Max background upload size (MB) for /api/generate. Default 256.
# MAX_UPLOAD_MB=256

# Docker Compose: MinIO + S3 — set only via compose file unless you override.
# S3_ENDPOINT_URL=http://minio:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# S3_BUCKET=brainrot


KOKORO_BASE_URL=https://api.kokoro.dok.inkyg.com/v1