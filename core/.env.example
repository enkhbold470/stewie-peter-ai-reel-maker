# Copy to `.env` at the repository root and fill in values (never commit `.env`).

OPENAI_API_KEY=

# OpenAI-compatible base URL for chat + Whisper (Dedalus, etc.). Trailing slash optional.
OPENAI_BASE_URL=https://api.dedaluslabs.ai/v1

# Optional: chat model id for generate_dialogue (override default in code).
# DEFAULT_GPT_MODEL=xai/grok-4-fast-reasoning

KOKORO_BASE_URL=https://api.kokoro.dok.inkyg.com/v1
