# Public URL of the Flask API (no trailing slash). Overrides automatic api.<hostname> in production.
# Leave unset when the API is at https://api.<same-hostname-as-this-SPA> (e.g. app on
# obsidian-studio.dok.inkyg.com → API on api.obsidian-studio.dok.inkyg.com).
# Local dev: leave unset (Vite proxies /api). If API is on another host, set this explicitly.
# Backend CORS_ORIGINS must include this SPA’s origin (e.g. https://obsidian-studio.dok.inkyg.com).
# VITE_API_BASE_URL=

# Dev server only (vite.config.ts — not available as import.meta.env in config):
# VITE_PORT=5173
# VITE_HOST=0.0.0.0
# Forward /api to local Flask or remote API (default http://127.0.0.1:5001)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5001
